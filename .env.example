# ===== 数据库 =====
# Postgres 连接串，例如：
#   postgresql://user:password@host:5432/stscan?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/stscan"

# ===== 扫描（/api/scan 触发用）=====
# 用于保护 /api/scan 免被外部随意触发；cron 调用时带 ?token=xxx
# 留空则不校验
SCAN_TOKEN=""

# ===== Telegram 推送（可选，不配则跳过推送）=====
# 1. 找 @BotFather 创建 bot 拿到 token
# 2. 把 bot 拉进群/频道，或获取你的 chat id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
